# ============================================================
# ARC TESTNET CONFIGURATION
# ============================================================

# Arc Testnet RPC URL (provided by Arc)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# ============================================================
# WALLET PRIVATE KEY (⚠️ KEEP THIS SECURE!)
# ============================================================
# 
# HOW TO GET YOUR PRIVATE KEY SAFELY:
# 1. MetaMask: Settings → Security & Privacy → Export Private Key
# 2. Rabby: Settings → Wallets → View Secret Key
# 3. Never share this with anyone!
# 4. Never commit to git (it's in .gitignore)
#
# FOR TESTING ONLY:
# Use a test wallet with only small amounts of testnet tokens
# Never use your mainnet private key here!
#
# Format: Paste without the 0x prefix
# Example: abcdef123456789...
PRIVATE_KEY=your_test_wallet_private_key_here

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
# After deployment, save your contract addresses here
# These will be used by the frontend

# PayAfterProof contract address (from deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# USDC token address on Arc Testnet
NEXT_PUBLIC_USDC_ADDRESS=0x...

# Arc Testnet Chain ID
NEXT_PUBLIC_CHAIN_ID=5042002

# ============================================================
# OPTIONAL: GAS REPORTER (for analyzing gas costs)
# ============================================================
REPORT_GAS=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_optional

# ============================================================
# OPTIONAL: BLOCK EXPLORER (for contract verification)
# ============================================================
ETHERSCAN_API_KEY=your_explorer_api_key_optional
